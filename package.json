{
  "name": "haven",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~55.0.4",
    "expo-font": "~55.0.4",
    "expo-router": "~55.0.3",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.0.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.10",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.0.0",
    "jest-expo": "^55.0.9",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironmentOptions": {},
    "projects": [
      {
        "displayName": "node",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/src/**/__tests__/**/*.test.ts"
        ],
        "transform": {
          "^.+\\.(ts|tsx)$": "babel-jest"
        }
      },
      {
        "displayName": "ios",
        "preset": "jest-expo/ios",
        "testMatch": [
          "<rootDir>/app/**/__tests__/**/*.test.{ts,tsx}",
          "<rootDir>/__tests__/**/*.test.{ts,tsx}"
        ]
      }
    ]
  },
  "private": true
}
